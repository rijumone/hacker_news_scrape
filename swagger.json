          }
        ],
        "responses": {
          "200": {
            "description": "Post with nested comment tree",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/hacker_news/stats/{time_period}/posts_highest_comment_count": {
