{
  "openapi": "3.0.3",
  "info": {
    "title": "Hacker News Scrape API",
    "version": "1.0.0",
    "description": "API for retrieving Hacker News post/comment data and aggregate statistics."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Content"
    },
    {
      "name": "Statistics"
    }
  ],
  "paths": {
    "/api/hacker_news/comment/{comment_id}": {
      "get": {
        "tags": ["Content"],
        "summary": "Get comment by id",
        "parameters": [
          {
            "name": "comment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Comment payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "404": {
            "description": "Comment not found"
          }
        }
      }
    },
    "/api/hacker_news/post": {
      "get": {
        "tags": ["Content"],
        "summary": "Get all posts",
        "responses": {
          "200": {
            "description": "Posts payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Post"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/hacker_news/post/{post_id}": {
      "get": {
        "tags": ["Content"],
        "summary": "Get post by id",
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "404": {
            "description": "Post not found"
          }
        }
      }
    },
