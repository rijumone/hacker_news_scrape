  },
  "components": {
    "parameters": {
      "TimePeriod": {
        "name": "time_period",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["hour", "day", "week", "all"]
        }
      },
      "Count": {
        "name": "count",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "schemas": {
      "Comment": {
        "type": "object",
        "properties": {
          "content": { "type": "string" },
          "created": { "type": "string" },
          "feed_rank": { "type": "integer" },
          "level": { "type": "integer" },
          "parent_comment": { "type": ["integer", "null"] },
          "post_id": { "type": "integer" },
          "username": { "type": "string" }
        }
      },
      "CommentWithWordCount": {
        "allOf": [
          { "$ref": "#/components/schemas/Comment" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "total_word_count": { "type": "integer" }
            }
          }
        ]
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "comment_count": { "type": "integer" },
          "created": { "type": "string" },
          "feed_rank": { "type": "integer" },
          "link": { "type": "string" },
          "point_count": { "type": "integer" },
          "title": { "type": "string" },
          "type": { "type": "string" },
          "username": { "type": "string" },
          "website": { "type": "string" }
        }
      },
      "WordFrequency": {
        "type": "object",
        "properties": {
          "word": { "type": "string" },
          "ndoc": { "type": "integer" },
          "nentry": { "type": "integer" }
        }
      },
      "PostTypeCount": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "type": { "type": "string" }
        }
      },
      "WebsiteCount": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "website": { "type": "string" }
        }
      },
      "UserCommentCount": {
        "type": "object",
        "properties": {
          "comment_count": { "type": "integer" },
          "username": { "type": "string" }
        }
      },
      "UserPostCount": {
        "type": "object",
        "properties": {
          "post_count": { "type": "integer" },
          "username": { "type": "string" }
        }
      },
      "UserWordCount": {
        "type": "object",
        "properties": {
          "comment_count": { "type": "integer" },
          "username": { "type": "string" },
          "word_count": { "type": "integer" }
        }
      }
    }
  }
}
